APP_ENV=dev
APP_NAME=els
TZ=Europe/Moscow
PGTZ=Europe/Moscow

LOG_LEVEL=debug
LOG_FORMAT=text
LOG_ADD_SOURCE=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=els
POSTGRES_PASSWORD=els
POSTGRES_DATABASE=els
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=Europe/Moscow
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONNECT_TIMEOUT=5s

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=5s

APP_HTTP_ADDR=:8080
APP_HTTP_READ_TIMEOUT=10s
APP_HTTP_WRITE_TIMEOUT=1500s
APP_HTTP_IDLE_TIMEOUT=60s
APP_HTTP_SHUTDOWN_TIMEOUT=15s

AUTH_HTTP_ADDR=:8081
AUTH_HTTP_READ_TIMEOUT=10s
AUTH_HTTP_WRITE_TIMEOUT=10s
AUTH_HTTP_IDLE_TIMEOUT=60s
AUTH_HTTP_SHUTDOWN_TIMEOUT=15s

AUTH_SESSION_TTL=8760h
AUTH_SESSION_KEY_PREFIX=session:

AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_MAX_LENGTH=128
AUTH_PASSWORD_ARGON2_MEMORY_KIB=65536
AUTH_PASSWORD_ARGON2_TIME=3
AUTH_PASSWORD_ARGON2_THREADS=2
AUTH_PASSWORD_ARGON2_SALT_LEN=16
AUTH_PASSWORD_ARGON2_KEY_LEN=32

INVITE_KEY_PREFIX=invite:
INVITE_SET_PASSWORD_TTL=72h
INVITE_MAGIC_LOGIN_TTL=15m
INVITE_RESET_PASSWORD_TTL=1h
INVITE_MAGIC_LOGIN_PERSISTENT=false
INVITE_SET_PASSWORD_URL=http://localhost:5173/set-password?token={token}
INVITE_MAGIC_LOGIN_URL=http://localhost:5173/login/confirm?token={token}
INVITE_RESET_PASSWORD_URL=http://localhost:5173/reset-password?token={token}

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ELS
SMTP_SECURE=true

IMPERSONATION_ENABLED=false

SECURITY_BODY_MAX_BYTES=1048576
SECURITY_UPLOAD_MAX_BYTES=10485760
SECURITY_UPLOAD_PATH_PREFIX=/api/v1/account
SECURITY_CORS_ALLOWED_ORIGINS=
SECURITY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
SECURITY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,Idempotency-Key
SECURITY_CORS_EXPOSED_HEADERS=X-Request-ID
SECURITY_CORS_MAX_AGE=600s
SECURITY_HSTS_MAX_AGE=31536000s
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_DOCS_ENABLED=true
SECURITY_AUTH_RATE_LIMIT=10
SECURITY_AUTH_RATE_WINDOW=60s
SECURITY_AUTH_LOCKOUT_ATTEMPTS=10
SECURITY_AUTH_LOCKOUT_WINDOW=15m

BOOTSTRAP_ADMIN_EMAIL=admin@els.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-please
BOOTSTRAP_ADMIN_USE_INVITE=false
BOOTSTRAP_ADMIN_FIRST_NAME=Global
BOOTSTRAP_ADMIN_LAST_NAME=Administrator

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=els
S3_SECRET_KEY=els-minio
S3_USE_SSL=false
S3_REGION=us-east-1
MEDIA_PUBLIC_URL_BASE=/api/v1/media
S3_AVATAR_BUCKET=avatars

COREENGINE_HTTP_ADDR=:8090
COREENGINE_HTTP_READ_TIMEOUT=10s
COREENGINE_HTTP_WRITE_TIMEOUT=10s
COREENGINE_HTTP_IDLE_TIMEOUT=60s
COREENGINE_HTTP_SHUTDOWN_TIMEOUT=15s
COREENGINE_WORKER_INTERVAL=5s
COREENGINE_WORKER_BATCH=10

# Background event processing (raw events -> structured + catalog enrichment).
# Collection (ingest) always works; this only toggles the LLM processing workers.
CORE_WORKER_ENABLED=true

SPACY_URL=http://localhost:8000

# Main LLM (agent chat, generation). Seeds the "main" provider in Settings on first run.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# Analysis LLM (vocab analyze, quest grammar). Falls back to main when empty.
LLM_ANALYSIS_BASE_URL=
LLM_ANALYSIS_API_KEY=
LLM_ANALYSIS_MODEL=

# Vision LLM (reads film frames for the agent). Falls back to main when empty.
LLM_VISION_BASE_URL=
LLM_VISION_API_KEY=
LLM_VISION_MODEL=

# Image generation (illustrations, quest images).
IMAGE_API_URL=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_TIMEOUT_SECONDS=180

# After first start these values are stored in the DB (ai_providers) and managed
# from the Settings app; env is only the initial seed.
